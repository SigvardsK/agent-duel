# Required
ANTHROPIC_API_KEY=sk-ant-...

# Treasury wallet — base64-encoded secret key (64 bytes → base64)
# Generate: solana-keygen new --outfile treasury.keypair.json --no-bip39-passphrase
# Encode:   node -e "console.log(Buffer.from(JSON.parse(require('fs').readFileSync('treasury.keypair.json'))).toString('base64'))"
# IMPORTANT: Also save the keypair file locally as backup (covered by .gitignore)
TREASURY_PRIVATE_KEY=<base64-encoded-secret-key>

# Solana RPC endpoint (default: local validator)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Server port (Railway injects this automatically)
PORT=8080

# Admin API token for /api/start and /api/stop endpoints (optional)
ADMIN_TOKEN=your-secret-token-here
