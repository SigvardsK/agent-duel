{
  "name": "agent-duel",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "wallet-test": "tsx src/main.ts --level 1",
    "game-test": "tsx src/main.ts --level 2",
    "agents": "tsx src/main.ts --level 3",
    "demo": "tsx src/demo.ts",
    "demo:auto": "tsx src/demo.ts --auto --rounds 50",
    "demo:auto:short": "tsx src/demo.ts --auto --rounds 5",
    "demo:web": "tsx src/demo.ts --web",
    "demo:web:auto": "tsx src/demo.ts --web --auto --rounds 50",
    "demo:web:auto:fast": "tsx src/demo.ts --web --auto --rounds 9999 --delay 30",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@solana/web3.js": "^1.98.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
